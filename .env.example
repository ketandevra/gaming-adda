# Google Apps Script web app URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# GitHub Pages project site path (repo: gaming-adda → /gaming-adda)
# Leave empty for local dev at http://localhost:3000
# NEXT_PUBLIC_BASE_PATH=/gaming-adda

# Local dev: use Next.js /api/sheets proxy (default on localhost & LAN IP like 192.168.x.x).
# GitHub Pages: must be false — browser calls Apps Script directly (enable CORS on script).
# NEXT_PUBLIC_USE_API_PROXY=true

# Use mock data instead of the API
NEXT_PUBLIC_USE_MOCK_DATA=false

# Optional: POST action name for creating bookings (if your script uses doPost)
NEXT_PUBLIC_SHEETS_ACTION_CREATE_BOOKING=createBooking

# Admin View Bookings (GET ?action=getBookings)
# NEXT_PUBLIC_SHEETS_ACTION_GET_BOOKINGS=getBookings
# NEXT_PUBLIC_SHEETS_ACTION_VERIFY_PAYMENT=verifyPayment

# UPI payment (opens UPI app after Confirm Booking; also shown on pending bookings)
NEXT_PUBLIC_PAYMENT_UPI_VPA=gplpali@ybl
NEXT_PUBLIC_PAYMENT_UPI_PAYEE_NAME=GPL Pali

# Admin login (mobile 9636933097 prompts for password; override defaults in production)
# NEXT_PUBLIC_ADMIN_MOBILE=9636933097
# NEXT_PUBLIC_ADMIN_PASSWORD=Gaming@1995
